{
  "module_id": "devin-hilly:baby-monitor",
  "visibility": "private",
  "url": "https://github.com/Simberific/baby-monitor-vision",
  "description": "Baby monitor awake detection module",
  "models": [
    {
      "api": "rdk:component:sensor",
      "model": "devin-hilly:baby-monitor:awake-classifier"
    },
    {
      "api": "rdk:service:vision",
      "model": "devin-hilly:baby-monitor:mock-eye-classifier"
    }
  ],
  "entrypoint": "./bin/baby-monitor",
  "build": {
    "build": "make module.tar.gz",
    "path": "module.tar.gz",
    "arch": ["linux/arm64", "darwin/arm64"]
  }
}
